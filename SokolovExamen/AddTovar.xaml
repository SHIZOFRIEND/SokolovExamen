<Window x:Class="SokolovExamen.AddTovar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SokolovExamen"
        Title="Товар"
        Height="600"
        Width="700"
       
        FontFamily="Calibri"
        FontSize="13">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">

            <Grid Margin="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
 
                <StackPanel Grid.Column="0"
                            Margin="5">

                    <TextBlock Text="ID"/>
                    <TextBox x:Name="tbId"
                             Margin="0,3,0,10"
                             IsReadOnly="True"/>

                    <TextBlock Text="Название"/>
                    <TextBox x:Name="tbName"
                             Margin="0,3,0,10"/>

                    <TextBlock Text="Категория"/>
                    <ComboBox x:Name="cbCategory"
                              Margin="0,3,0,10"/>

                    <TextBlock Text="Производитель"/>
                    <ComboBox x:Name="cbManufacturer"
                              Margin="0,3,0,10"/>

                    <TextBlock Text="Поставщик"/>
                    <ComboBox x:Name="cbSupplier"
                              Margin="0,3,0,10"/>

                    <TextBlock Text="Ед. изм"/>
                    <ComboBox x:Name="cbUnit"
                              Margin="0,3,0,10"/>

                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="5">

                    <TextBlock Text="Описание"/>

                    <TextBox x:Name="tbDescription"
                             Height="120"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,3,0,10"/>

                    <TextBlock Text="Цена"/>
                    <TextBox x:Name="tbCost"
                             Margin="0,3,0,10"/>

                    <TextBlock Text="Артикул"/>
                    <TextBox x:Name="tbArticle"
                             Margin="0,3,0,10"/>

                    <TextBlock Text="Склад"/>
                    <TextBox x:Name="tbStock"
                             Margin="0,3,0,10"/>

                    <TextBlock Text="Скидка %"/>
                    <TextBox x:Name="tbDiscount"
                             Margin="0,3,0,10"/>

                </StackPanel>

            </Grid>
        </ScrollViewer>
 
        <Grid Grid.Row="1">

            <Button Content="Сохранить"
                    Height="40"
                    Margin="484,0,5,0"
                    Background="#0000FF"
                    Foreground="White"
                    VerticalAlignment="Center"
                    Click="Save_Click"/>

        </Grid>

    </Grid>
</Window>